<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        android:background="#D1D1D1" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Request Extra Pickup"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Schedule an additional collection outside your plan."
        android:textColor="#757575"
        android:textSize="14sp" />

    <!-- Waste Type -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Waste Type"
        android:textColor="#333333"
        android:textStyle="bold" />
    <Spinner
        android:id="@+id/spinner_pickup_type"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/edit_text_border"
        android:entries="@array/garbage_types" />

    <!-- Pickup Date -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Preferred Date"
        android:textColor="#333333"
        android:textStyle="bold" />
    <EditText
        android:id="@+id/et_pickup_date"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/edit_text_border"
        android:focusable="false"
        android:hint="Select Date"
        android:paddingHorizontal="12dp"
        android:inputType="none" />

    <!-- Location -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Pickup Address"
        android:textColor="#333333"
        android:textStyle="bold" />
    <EditText
        android:id="@+id/et_pickup_address"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/edit_text_border"
        android:hint="e.g. Plot 12, Kampala Rd"
        android:paddingHorizontal="12dp"
        android:inputType="textPostalAddress" />

    <!-- Cost Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Service Fee:"
            android:textColor="#333333" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UGX 5,000"
            android:textColor="#009688"
            android:textStyle="bold"
            android:textSize="18sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_submit_pickup"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="#009688"
        android:text="Confirm &amp; Request"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        app:cornerRadius="12dp" />

</LinearLayout>